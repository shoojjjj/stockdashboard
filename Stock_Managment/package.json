{
  "name": "stock-managment",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build:data": "python scripts/build_dashboard.py",
    "build:data:safe": "python scripts/build_dashboard.py || echo skip",
    "dev": "npm run build:data && next dev",
    "build": "npm run build:data:safe && next build",
    "start": "next start",
    "lint": "next lint",
    "health": "python scripts/health_check.py",
    "report": "python scripts/generate_progress_report.py --step3-done --step4-done --vercel-password-set --force-open",
    "results": "python scripts/generate_results_report.py",
    "deploy": "powershell -ExecutionPolicy Bypass -File scripts/auto_deploy.ps1",
    "deploy:quick": "powershell -ExecutionPolicy Bypass -File scripts/auto_deploy.ps1 -SkipTelegram"
  },
  "dependencies": {
    "next": "^15.3.3",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.1.8",
    "@types/node": "^22.15.21",
    "@types/react": "^19.1.4",
    "@types/react-dom": "^19.1.5",
    "eslint": "^9.27.0",
    "eslint-config-next": "^15.3.3",
    "tailwindcss": "^4.1.8",
    "typescript": "^5.8.3"
  }
}

# 네이버 프리미엄(자산제곱) 칼럼 자동 수집 설정
# 이 파일을 column_collect.env 로 복사한 뒤 NAVER_COOKIE 를 채우세요.

# 1) Chrome에서 https://nid.naver.com 로 로그인
# 2) https://contents.premium.naver.com/assetx2/assetsx2/contents 접속 (구독 확인)
# 3) F12 → Network → 글 하나 클릭 → 아무 요청 → Request Headers → Cookie 전체 복사
NAVER_COOKIE=

# 또는 쿠키 파일 경로 (한 줄 Cookie 헤더)
# NAVER_COOKIE_FILE=C:\path\to\naver_cookie.txt

# 목록 스캔 페이지 수 (20개/페이지)
COLUMN_LIST_PAGES=3

# 1회 실행 시 최대 저장 개수
COLUMN_NEW_LIMIT=10
